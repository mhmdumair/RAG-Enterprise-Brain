# ── MongoDB ───────────────────────────────────────────────────────────────────
# Development (local)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=enterprise_brain

# Production (swap this one line when moving to Atlas)
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net

# ── Collections ───────────────────────────────────────────────────────────────
COLLECTION_DOCUMENTS=documents
COLLECTION_CHUNKS=chunks
COLLECTION_RESULTS=results

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TITLE=Enterprise Brain API
API_VERSION=0.1.0

# ── Storage paths ─────────────────────────────────────────────────────────────
UPLOAD_DIR=storage/uploads
FAISS_INDEX_PATH=storage/indexes/brain.index
MODEL_CACHE_DIR=storage/models

# ── Embedding model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── QA model ──────────────────────────────────────────────────────────────────
QA_MODEL_NAME=deepset/roberta-base-squad2
QA_MAX_ANSWER_LEN=100
QA_MAX_SEQ_LEN=512
QA_DOC_STRIDE=128

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_CHUNKS=5

# ── Abstention threshold ──────────────────────────────────────────────────────
# A span is accepted only when S_span > S_null + TAU_ANS
# 0.1 is a safe starting point — increase to be more strict
TAU_ANS=0.1

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# ── Ingestion limits ──────────────────────────────────────────────────────────
MAX_PDFS=10
MAX_PAGES_PER_PDF=20
MAX_FILE_SIZE_MB=50

# ── FAISS HNSW ────────────────────────────────────────────────────────────────
FAISS_HNSW_M=32
FAISS_HNSW_EF_CONSTRUCTION=200
FAISS_HNSW_EF_SEARCH=128

# ── RAKE fallback ─────────────────────────────────────────────────────────────
RAKE_MAX_WORDS=3
RAKE_TOP_N=5

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Set True in production for structured JSON logs
LOG_JSON=False